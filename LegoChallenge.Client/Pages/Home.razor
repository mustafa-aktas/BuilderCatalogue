@page "/"
@rendermode InteractiveAuto
@inject LegoApiService Api
@inject UserCacheService UserCache
@inject ActiveUserService ActiveUser
@inject ColorService Colours

<PageTitle>LEGO Challenge — @(ActiveUser.CurrentUser?.Username ?? "")</PageTitle>

@if (_loading)
{
    <div class="d-flex flex-column align-items-center justify-content-center mt-5 gap-3">
        <div class="spinner-border text-warning" style="width:3rem;height:3rem;" role="status">
            <span class="visually-hidden">Loading…</span>
        </div>
        <p class="text-muted">Fetching inventory and sets…</p>
    </div>
}
else if (_error is not null)
{
    <div class="alert alert-danger mt-3">
        <h5 class="alert-heading">Failed to load data</h5>
        <p class="mb-2">@_error</p>
        <button class="btn btn-sm btn-danger" @onclick="() => LoadDataAsync()">Retry</button>
    </div>
}
else if (_user is not null)
{
    <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
        <div>
            <h1 class="mb-1">
                <span class="lego-stud">&#9632;</span> @_user.Username
            </h1>
            <span class="text-muted small">
                @_user.Location &nbsp;·&nbsp; @_user.BrickCount.ToString("N0") pieces in inventory
                &nbsp;·&nbsp; @_user.Collection.Count distinct part types
            </span>
        </div>
        <button class="btn btn-outline-secondary btn-sm mt-1"
                @onclick="() => LoadDataAsync(refresh: true)"
                disabled="@_refreshing">
            @if (_refreshing)
            {
                <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
            }
            ↻ Refresh inventory
        </button>
    </div>

    <div class="row g-2 mb-4">
        <div class="col-auto">
            <span class="badge bg-success fs-6 px-3 py-2">
                ✅ @_canBuild.Count can build
            </span>
        </div>
        <div class="col-auto">
            <span class="badge bg-danger fs-6 px-3 py-2">
                ❌ @_cannotBuild.Count cannot build
            </span>
        </div>
        <div class="col-auto">
            <span class="badge bg-secondary fs-6 px-3 py-2">
                @_results.Count total sets
            </span>
        </div>
    </div>

    @if (_canBuild.Count > 0)
    {
        <h4 class="text-success mb-3">Can Build</h4>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3 mb-5">
            @foreach (var r in _canBuild.OrderBy(r => r.Set.Name))
            {
                <div class="col">
                    <div class="card border-success h-100 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title text-capitalize fw-bold">
                                @r.Set.Name.Replace('-', ' ')
                            </h6>
                            <p class="card-text text-muted small mb-2">
                                @r.Set.SetNumber &nbsp;·&nbsp; @r.Set.TotalPieces.ToString("N0") pieces
                            </p>
                            <span class="badge bg-success">Ready to build</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (_cannotBuild.Count > 0)
    {
        <h4 class="text-danger mb-3">Cannot Build</h4>
        <div class="d-flex flex-column gap-2 mb-4">
            @foreach (var r in _cannotBuild.OrderBy(r => r.Missing.Count))
            {
                var setId    = r.Set.Id;
                var expanded = _expanded.Contains(setId);

                <div class="card border-danger shadow-sm">
                    <div class="card-header d-flex justify-content-between align-items-center"
                         style="cursor:pointer"
                         @onclick="() => ToggleExpand(setId)">
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <span class="fw-bold text-capitalize">@r.Set.Name.Replace('-', ' ')</span>
                            <span class="badge bg-secondary">@r.Set.TotalPieces.ToString("N0") pieces</span>
                            <span class="badge bg-danger">@r.Missing.Count missing type(s)</span>
                            @if (_subResults.TryGetValue(setId, out var subBadge))
                            {
                                @if (subBadge.CanBuild)
                                {
                                    <span class="badge bg-success">🔄 Buildable with substitution</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">No substitution found</span>
                                }
                            }
                        </div>
                        <span class="text-muted">@(expanded ? "▲" : "▼")</span>
                    </div>

                    @if (expanded)
                    {
                        <div class="card-body p-0">

                            @* ── Missing pieces ──────────────────────────── *@
                            <table class="table table-sm table-striped mb-0">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Part ID</th>
                                        <th>Color</th>
                                        <th class="text-end">Required</th>
                                        <th class="text-end">Have</th>
                                        <th class="text-end">Short by</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var m in r.Missing.OrderByDescending(m => m.ShortBy))
                                    {
                                        <tr>
                                            <td><code>@m.DesignId</code></td>
                                            <td>
                                                <span class="color-swatch me-1" style="background:@GetColorHint(m.ColorCode)"></span>
                                                @GetColorName(m.ColorCode)
                                            </td>
                                            <td class="text-end">@m.Required</td>
                                            <td class="text-end @(m.Have == 0 ? "text-danger fw-bold" : "")">@m.Have</td>
                                            <td class="text-end text-danger fw-bold">@m.ShortBy</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>

                            @* ── Actions ─────────────────────────────────── *@
                            <div class="p-3 border-top d-flex flex-wrap gap-3 align-items-center">
                                <button class="btn btn-outline-primary btn-sm"
                                        @onclick="() => FindCollaboratorsAsync(setId)"
                                        disabled="@_findingCollabs.Contains(setId)">
                                    @if (_findingCollabs.Contains(setId))
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                                    }
                                    Find minimum collaborators
                                </button>
                            </div>

                            @* ── Colour substitution result ───────────────── *@
                            @if (_subResults.TryGetValue(setId, out var subResult))
                            {
                                <div class="p-3 border-top">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="fw-semibold small text-info">With colour substitution</span>
                                        @if (subResult.CanBuild)
                                        {
                                            <span class="badge bg-success">✅ Can build!</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Still cannot build</span>
                                        }
                                    </div>
                                    @if (subResult.Substitutions.Count > 0)
                                    {
                                        <table class="table table-sm mb-0">
                                            <thead class="table-dark">
                                                <tr>
                                                    <th>Replace all pieces of colour</th>
                                                    <th></th>
                                                    <th>With</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var s in subResult.Substitutions)
                                                {
                                                    <tr>
                                                        <td>
                                                            <span class="color-swatch me-1" style="background:@GetColorHint(s.OriginalColor)"></span>
                                                            @GetColorName(s.OriginalColor)
                                                        </td>
                                                        <td class="text-muted">→</td>
                                                        <td>
                                                            <span class="color-swatch me-1" style="background:@GetColorHint(s.SubstituteColor)"></span>
                                                            @GetColorName(s.SubstituteColor)
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                    @if (!subResult.CanBuild && subResult.Missing.Count > 0)
                                    {
                                        <p class="small text-danger mb-0 mt-1">
                                            @subResult.Missing.Count type(s) still missing after substitution.
                                        </p>
                                    }
                                </div>
                            }

                            @* ── Collaboration result ─────────────────────── *@
                            @if (_collabResults.TryGetValue(setId, out var collabResult))
                            {
                                <div class="p-3 border-top">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="fw-semibold small">Collaboration</span>
                                        @if (collabResult.Solvable)
                                        {
                                            <span class="badge bg-success">✅ Buildable together!</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Not enough pieces even together</span>
                                        }
                                    </div>
                                    @if (collabResult.Collaborators.Count > 0)
                                    {
                                        <div class="d-flex flex-column gap-1">
                                            @foreach (var c in collabResult.Collaborators)
                                            {
                                                <div class="d-flex justify-content-between align-items-center small">
                                                    <span>
                                                        <strong>@c.User.Username</strong>
                                                        <span class="text-muted ms-1">@c.User.Location</span>
                                                    </span>
                                                    <span class="badge bg-secondary">
                                                        @c.Pieces.Sum(p => p.Quantity) pcs · @c.Pieces.Count type(s)
                                                    </span>
                                                </div>
                                            }
                                        </div>
                                    }
                                    @if (collabResult.StillMissing.Count > 0)
                                    {
                                        <p class="small text-danger mb-0 mt-2">
                                            @collabResult.StillMissing.Count type(s) still missing with all users.
                                        </p>
                                    }
                                </div>
                            }

                        </div>
                    }
                </div>
            }
        </div>
    }
}

@code {
    private User? _user;
    private List<BuildResult> _results    = [];
    private List<BuildResult> _canBuild   = [];
    private List<BuildResult> _cannotBuild = [];
    private readonly HashSet<string> _expanded = [];

    private bool    _loading    = true;
    private bool    _refreshing;
    private string? _error;

    private Dictionary<string, LegoSet> _setDetails = [];
    private readonly Dictionary<string, SubstitutedBuildResult> _subResults    = [];
    private readonly Dictionary<string, CollaborationResult>    _collabResults = [];
    private readonly HashSet<string>    _findingCollabs = [];
    private List<(UserSummary Summary, User Detail)>? _otherUsers;

    protected override async Task OnInitializedAsync() => await LoadDataAsync();

    private async Task LoadDataAsync(bool refresh = false)
    {
        _loading    = !refresh;
        _refreshing = refresh;
        _error      = null;

        if (refresh)
        {
            _subResults.Clear();
            _collabResults.Clear();
            _otherUsers = null;
        }

        try
        {
            _user = await UserCache.GetUserAsync(ActiveUser.CurrentUser!.Id, forceRefresh: refresh);

            var setsTask = Api.GetSetsAsync();
            var sets     = await setsTask;
            var setDetails = await Task.WhenAll(sets.Select(s => Api.GetSetByIdAsync(s.Id)));

            _setDetails = [];
            _results    = [];
            for (var i = 0; i < sets.Count; i++)
            {
                _setDetails[sets[i].Id] = setDetails[i];
                _results.Add(BuildAnalysisService.Analyze(sets[i], setDetails[i], _user));
            }

            _canBuild    = _results.Where(r =>  r.CanBuild).ToList();
            _cannotBuild = _results.Where(r => !r.CanBuild).ToList();

            _subResults.Clear();
            foreach (var r in _cannotBuild)
            {
                if (_setDetails.TryGetValue(r.Set.Id, out var detail))
                    _subResults[r.Set.Id] = ColorSubstitutionService.Analyze(detail, _user);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading    = false;
            _refreshing = false;
        }
    }

    private void ToggleExpand(string setId)
    {
        if (_expanded.Contains(setId))
        {
            _expanded.Remove(setId);
        }
        else
        {
            _expanded.Clear();
            _expanded.Add(setId);
        }
    }

    private async Task FindCollaboratorsAsync(string setId)
    {
        if (_user is null || !_setDetails.TryGetValue(setId, out var set)) return;

        _findingCollabs.Add(setId);
        _collabResults.Remove(setId);

        try
        {
            await EnsureOtherUsersAsync();
            _collabResults[setId] = CollaborationService.FindMinimumCollaborators(set, _user, _otherUsers!);
        }
        finally
        {
            _findingCollabs.Remove(setId);
        }
    }

    private async Task EnsureOtherUsersAsync()
    {
        if (_otherUsers is not null) return;
        var all    = await Api.GetUsersAsync();
        var others = all.Where(u => u.Id != _user!.Id).ToList();
        var details = await Task.WhenAll(others.Select(u => UserCache.GetUserAsync(u.Id)));
        _otherUsers = others.Zip(details).Select(x => (x.Item1, x.Item2)).ToList();
    }

    private string GetColorName(int code) => Colours.GetName(code);
    private string GetColorHint(int code) => Colours.GetHint(code);
}
