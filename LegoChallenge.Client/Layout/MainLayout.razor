@inherits LayoutComponentBase
@implements IDisposable
@inject ActiveUserService ActiveUser

@if (ActiveUser.CurrentUser is null)
{
    <LoginPanel />
}
else
{
    <div class="page">
        <div class="sidebar">
            <NavMenu />
        </div>

        <main>
            <div class="top-row px-4 d-flex justify-content-between align-items-center">
                <span class="text-muted small">
                    <span class="lego-stud">&#9632;</span> @ActiveUser.CurrentUser.Username
                </span>
                <button class="btn btn-link btn-sm text-muted p-0 text-decoration-none"
                        @onclick="ActiveUser.Logout">
                    Sign out
                </button>
            </div>

            <article class="content px-4">
                @Body
            </article>
        </main>
    </div>

    <div id="blazor-error-ui" data-nosnippet>
        An unhandled error has occurred.
        <a href="." class="reload">Reload</a>
        <span class="dismiss">🗙</span>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        ActiveUser.OnUserChanged += OnChanged;
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        ActiveUser.OnUserChanged -= OnChanged;
    }
}
